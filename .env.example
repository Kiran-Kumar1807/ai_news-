# ---------------------------------------------------------------------------
# AI-Powered Personalized News Aggregator - environment configuration
# Copy this file to `.env` and fill in the values.
# ---------------------------------------------------------------------------

# Application
APP_NAME="AI News Aggregator"
ENVIRONMENT=development
LOG_LEVEL=INFO

# Database (PostgreSQL). For docker-compose the host is `db`.
DATABASE_URL=postgresql+psycopg2://news:news@localhost:5432/news_aggregator

# JWT authentication
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Gemini API (leave empty to run with heuristic fallbacks)
GEMINI_API_KEY=
# gemini-flash-lite-latest works on the free tier; use gemini-2.5-pro/flash on paid plans
GEMINI_MODEL=gemini-flash-lite-latest
# Throttle Gemini calls to stay under the free-tier limit (~15/min); retries on 429
GEMINI_MAX_RPM=12
GEMINI_MAX_RETRIES=2

# Extra free-tier LLM providers. The router tries them in LLM_PROVIDER_ORDER and
# fails over to the next on rate-limit/error (only providers with a key run).
# Groq: https://console.groq.com/keys   OpenRouter: https://openrouter.ai/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
LLM_PROVIDER_ORDER=groq,gemini,openrouter

# Ingestion / scheduler
INGEST_INTERVAL_MINUTES=60
ENABLE_SCHEDULER=true
# Run one ingestion pass ~15s after startup so a fresh deploy has content
INGEST_ON_STARTUP=true
MAX_ARTICLES_PER_FEED=8

# Token to authorize POST /admin/ingest (manual ingestion trigger). Empty disables it.
ADMIN_TOKEN=

# Daily email digest (Gmail SMTP). Leave SMTP_USERNAME empty to disable sending.
DIGEST_HOUR=7
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM="AI News Aggregator <noreply@example.com>"

# Frontend -> backend
API_BASE_URL=http://localhost:8000

# CORS: comma-separated allowed origins, or * for any (set to the frontend URL in prod)
CORS_ORIGINS=*
